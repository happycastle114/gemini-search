{
  "name": "@happycastle/gemini-search",
  "version": "1.3.3",
  "description": "Web search plugin for Claude Code — Gemini CLI with Google Search grounding, JSON parsing, and source citations",
  "type": "module",
  "license": "MIT",
  "author": "happycastle",
  "repository": {
    "type": "git",
    "url": "https://github.com/happycastle114/gemini-search.git"
  },
  "bin": {
    "gemini-search": "./bin/gemini-search.mjs",
    "gemini-search-mcp": "./bin/gemini-search-mcp.mjs"
  },
  "files": [
    ".claude-plugin",
    "skills",
    "commands",
    "hooks",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test test/wrapper.test.mjs test/mcp-smoke.test.mjs",
    "lint": "node --check bin/gemini-search.mjs && node --check bin/gemini-search-mcp.mjs",
    "release": "semantic-release",
    "prepublishOnly": "npm run lint && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "conventional-changelog-conventionalcommits": "8.0.0",
    "semantic-release": "25.0.3"
  },
  "overrides": {
    "brace-expansion": ">=2.0.3",
    "picomatch": ">=4.0.4"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "gemini",
    "web-search",
    "google-search",
    "grounding",
    "research"
  ]
}
