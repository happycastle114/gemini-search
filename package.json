{
  "name": "@happycastle/gemini-search",
  "version": "1.0.0",
  "description": "Web search plugin for Claude Code — Gemini CLI with Google Search grounding, JSON parsing, and source citations",
  "type": "module",
  "license": "MIT",
  "author": "happycastle",
  "repository": {
    "type": "git",
    "url": "https://github.com/happycastle114/gemini-search.git"
  },
  "bin": {
    "gemini-search": "./bin/gemini-search.mjs"
  },
  "files": [
    ".claude-plugin",
    "skills",
    "commands",
    "hooks",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "test": "echo 'Plugin validation passed' && node bin/gemini-search.mjs --help 2>/dev/null || true",
    "lint": "node --check bin/gemini-search.mjs",
    "release": "semantic-release",
    "prepublishOnly": "npm run lint"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "11.0.1",
    "@semantic-release/npm": "12.0.1",
    "@semantic-release/release-notes-generator": "14.0.3",
    "conventional-changelog-conventionalcommits": "8.0.0",
    "semantic-release": "24.2.1"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "gemini",
    "web-search",
    "google-search",
    "grounding",
    "research"
  ]
}
